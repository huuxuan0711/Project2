<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/weekly_overview_background"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".presentation.settings.SettingHubFragment">

    <!-- Scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:text="Settings"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Manage your data, preferences, and app information."
                    android:textSize="18sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Data Status Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="16dp"
                android:padding="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_search">

                <TextView
                    android:text="Data Status"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Local data -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:background="@drawable/bg_circle_amber"
                        android:backgroundTint="#EEF0F8"
                        android:padding="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/database"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="20dp"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Local data"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <TextView
                            android:id="@+id/txtStatusData"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active"
                            android:textSize="16sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/viewStatusData"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:backgroundTint="#10B981"
                        android:background="@drawable/bg_button_rounded"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="#F3F4F6"/>

                <!-- Cloud backup -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:background="@drawable/bg_circle_amber"
                        android:backgroundTint="#EEF0F8"
                        android:padding="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/cloud"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="20dp"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cloud backup"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <TextView
                            android:id="@+id/txtStatusCloud"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not configured"
                            android:textSize="16sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/viewStatusCloud"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:backgroundTint="#9CA3AF"
                        android:background="@drawable/bg_button_rounded"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Settings List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:background="@drawable/bg_search">

                <!-- Item 1 -->
                <LinearLayout
                    android:id="@+id/layoutPrivacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:background="@drawable/bg_circle_amber"
                        android:backgroundTint="#EEF0F8"
                        android:padding="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/shield"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginStart="20dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Privacy &amp; Data"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Control how your usage data is stored and managed."
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/chevron_right"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"/>

                <!-- Item 2 -->
                <LinearLayout
                    android:id="@+id/layoutPreferences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:background="@drawable/bg_circle_amber"
                        android:backgroundTint="#EEF0F8"
                        android:padding="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            app:tint="#5C6BC0"
                            android:src="@drawable/settings"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginStart="20dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Preferences"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Customize behavior analysis and app settings."
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/chevron_right"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"/>

                <!-- Item 3 -->
                <LinearLayout
                    android:id="@+id/layoutAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:background="@drawable/bg_circle_amber"
                        android:backgroundTint="#EEF0F8"
                        android:padding="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/info"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginStart="20dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="About"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textStyle="bold"
                            android:text="View app information, version details, and support links."
                            android:textSize="16sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/chevron_right"
                        app:tint="#9CA3AF" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>