<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB"
    tools:context=".presentation.analysis.BehaviorInsightDetailActivity">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/chevron_left"
            app:tint="#1A1A1A" />

        <TextView
            android:layout_marginStart="20dp"
            android:text="Behavior Insight"
            android:textSize="22sp"
            android:textColor="#1A1A1A"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- INSIGHT CARD -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:id="@+id/layoutIcon"
                            android:background="@drawable/bg_circle_amber"
                            android:backgroundTint="#E8F5E9"
                            android:padding="12dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/imgIcon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/trending_up"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:padding="14dp"
                            android:text="Pattern Detected"
                            android:textSize="16sp"
                            android:textColor="#4CAF50"
                            android:background="@drawable/bg_chip"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtPattern"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="You tend to switch between short-form social media apps during late-night sessions."
                        android:textSize="20sp"
                        android:textColor="#1A1A1A"/>
                </LinearLayout>

                <!-- METRICS CARD -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Supporting Metrics"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_marginBottom="20dp"/>

                    <!-- ITEM -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content">

                            <FrameLayout
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:backgroundTint="#EDE7F6"
                                android:background="@drawable/bg_app_icon">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/moon"/>
                            </FrameLayout>

                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Late-night usage ratio"
                                    android:textSize="18sp"
                                    android:textColor="#1A1A1A"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="After 11 PM"
                                    android:textSize="16sp"
                                    android:textColor="#6B7280"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtLateNightRatio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="67%"
                            android:textColor="#5C6BC0"
                            android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content">

                            <FrameLayout
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:backgroundTint="#EDE7F6"
                                android:background="@drawable/bg_app_icon">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/clock"/>
                            </FrameLayout>

                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Avg. session length"
                                    android:textSize="18sp"
                                    android:textColor="#1A1A1A"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Per app visit"
                                    android:textSize="16sp"
                                    android:textColor="#6B7280"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtAvgSessionLength"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3.2 min%"
                            android:textColor="#5C6BC0"
                            android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content">

                            <FrameLayout
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:backgroundTint="#EDE7F6"
                                android:background="@drawable/bg_app_icon">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/smartphone"/>
                            </FrameLayout>

                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="App transitions"
                                    android:textSize="18sp"
                                    android:textColor="#1A1A1A"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Per hour"
                                    android:textSize="16sp"
                                    android:textColor="#6B7280"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtAppTransitions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="#5C6BC0"
                            android:textSize="20sp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- WHAT THIS MEANS -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="What This Means"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Frequent switching between short-form apps may indicate passive browsing behavior and reduced focus. This pattern typically emerges when seeking quick dopamine hits rather than engaging with meaningful content."
                        android:textColor="#6B7280"
                        android:textSize="18sp"/>
                </LinearLayout>

                <!-- TIMELINE -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Activity Timeline"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="12dp"/>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peak activity detected between 11 PM - 1 AM"
                        android:textSize="16sp"
                        android:textColor="#6B7280"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- SUGGESTION -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="@drawable/bg_insight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:background="@drawable/bg_circle_amber"
                        android:backgroundTint="#FFFFFF"
                        android:padding="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/lightbulb"/>
                    </LinearLayout>

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_marginStart="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:layout_marginBottom="10dp"
                            android:text="Suggestion"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <TextView
                            android:id="@+id/txtSuggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Consider limiting social media use after midnightttttttttttttttttttttttttttttttttttttttttttttttttttttttt..."
                            android:textSize="16sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>