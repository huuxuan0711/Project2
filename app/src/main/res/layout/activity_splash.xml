<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#F6F7FB"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.onboarding.SplashActivity">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/loadingContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo"
            android:alpha="0"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:scaleX="0.9"
            android:scaleY="0.9"
            android:src="@drawable/digital_wellbeing_logo"/>

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:text="Digital Wellbeing"
            android:textSize="30sp"
            android:textColor="#1A1A1A"
            android:fontFamily="sans-serif-medium"
            android:translationY="10dp"
            android:layout_marginTop="24dp"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:text="Understand your digital habits"
            android:textSize="24sp"
            android:textColor="#6B7280"
            android:fontFamily="sans-serif-light"
            android:translationY="10dp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Loading dots -->
    <LinearLayout
        android:id="@+id/loadingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="80dp"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dot1"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dot"/>

        <View
            android:id="@+id/dot2"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dot"/>

        <View
            android:id="@+id/dot3"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dot"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>