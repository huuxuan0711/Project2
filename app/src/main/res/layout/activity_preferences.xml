<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/weekly_overview_background"
    tools:context=".presentation.settings.PreferencesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preferences"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"/>

        <!-- ================= ANALYSIS SETTINGS ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_search"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analysis Settings"
                android:textColor="#1A1A1A"
                android:textSize="24sp"
                android:textStyle="bold"
                android:padding="16dp"/>

            <!-- Late Night Threshold -->
            <LinearLayout
                android:padding="16dp"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:src="@drawable/clock"
                    android:layout_marginEnd="16dp"
                    android:layout_width="26dp"
                    android:layout_height="26dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Late Night Threshold"
                        android:textSize="20sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Define when app usage is considered late night"
                        android:textSize="18sp"
                        android:textColor="#6B7280"
                        android:layout_marginBottom="10dp"/>

                    <SeekBar
                        android:layout_height="20dp"
                        android:id="@+id/seekLateNight"
                        android:layout_width="match_parent"
                        android:max="5"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="8:00 PM"
                            android:textSize="16sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvLateNightValue"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:text="10:00 PM"
                            android:textColor="#5C6BC0"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="1:00 AM"
                            android:textSize="16sp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Session Length -->
            <LinearLayout
                android:padding="16dp"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:src="@drawable/smartphone"
                    android:layout_marginEnd="16dp"
                    android:layout_width="26dp"
                    android:layout_height="26dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Session Length Threshold"
                        android:layout_marginBottom="10dp"
                        android:textSize="20sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set when a session is considered long"
                        android:textSize="18sp"
                        android:textColor="#6B7280"
                        android:layout_marginBottom="10dp"/>

                    <SeekBar
                        android:layout_height="wrap_content"
                        android:id="@+id/seekSession"
                        android:layout_width="match_parent"
                        android:max="4"/>

                    <LinearLayout
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="10 min"
                            android:textSize="16sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvSessionValue"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:text="20 minutes"
                            android:textColor="#5C6BC0"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="30 min"
                            android:textSize="16sp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- App Category Tracking -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/trending_up"
                    app:tint="#5C6BC0"
                    android:layout_gravity="top"
                    android:layout_marginEnd="16dp"
                    android:layout_width="26dp"
                    android:layout_height="26dp"/>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="App Category Tracking"
                        android:layout_marginBottom="10dp"
                        android:textSize="20sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Include all app categories in analysis"
                        android:textSize="18sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    app:thumb="@drawable/switch_thumb"
                    app:track="@drawable/switch_track"
                    app:thumbTint="@null"
                    app:trackTint="@null"
                    android:showText="false"
                    app:switchMinWidth="44dp"
                    app:switchPadding="0dp"
                    android:minHeight="24dp"
                    android:minWidth="44dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ================= DISPLAY SETTINGS ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_search"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Display Settings"
                android:textColor="#1A1A1A"
                android:textSize="24sp"
                android:textStyle="bold"
                android:padding="16dp"/>

            <!-- Insight Notifications -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/bell"
                    app:tint="#5C6BC0"
                    android:layout_gravity="top"
                    android:layout_marginEnd="16dp"
                    android:layout_width="26dp"
                    android:layout_height="26dp"/>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Insight Notifications"
                        android:layout_marginBottom="10dp"
                        android:textSize="20sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get notified about behavior patterns"
                        android:textSize="18sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchInsight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    app:thumb="@drawable/switch_thumb"
                    app:track="@drawable/switch_track"
                    app:thumbTint="@null"
                    app:trackTint="@null"
                    android:showText="false"
                    app:switchMinWidth="44dp"
                    app:switchPadding="0dp"
                    android:minHeight="24dp"
                    android:minWidth="44dp" />
            </LinearLayout>

            <!-- Dark Mode -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/moon"
                    app:tint="#5C6BC0"
                    android:layout_gravity="top"
                    android:layout_marginEnd="16dp"
                    android:layout_width="26dp"
                    android:layout_height="26dp"/>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark Mode"
                        android:layout_marginBottom="10dp"
                        android:textSize="20sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Use dark theme throughout the app"
                        android:textSize="18sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    app:thumb="@drawable/switch_thumb"
                    app:track="@drawable/switch_track"
                    app:thumbTint="@null"
                    app:trackTint="@null"
                    android:showText="false"
                    app:switchMinWidth="44dp"
                    app:switchPadding="0dp"
                    android:minHeight="24dp"
                    android:minWidth="44dp" />
            </LinearLayout>

            <!-- Weekly Reports -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/file_text"
                    app:tint="#5C6BC0"
                    android:layout_gravity="top"
                    android:layout_marginEnd="16dp"
                    android:layout_width="26dp"
                    android:layout_height="26dp"/>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weekly Reports"
                        android:layout_marginBottom="10dp"
                        android:textSize="20sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Receive weekly usage summaries"
                        android:textSize="18sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchWeekly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    app:thumb="@drawable/switch_thumb"
                    app:track="@drawable/switch_track"
                    app:thumbTint="@null"
                    app:trackTint="@null"
                    android:showText="false"
                    app:switchMinWidth="44dp"
                    app:switchPadding="0dp"
                    android:minHeight="24dp"
                    android:minWidth="44dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ================= SENSITIVITY ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_search"
            android:elevation="2dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Insight Sensitivity"
                android:layout_marginBottom="10dp"
                android:textSize="20sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Control how sensitive pattern detection is"
                android:textSize="18sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="10dp"/>

            <SeekBar
                android:layout_height="wrap_content"
                android:id="@+id/seekSensitivity"
                android:layout_width="match_parent"
                android:max="2"/>

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Low"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvSensitivityValue"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:text="Medium"
                    android:textColor="#5C6BC0"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="High"
                    android:textSize="16sp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>